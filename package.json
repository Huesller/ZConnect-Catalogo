{
  "name": "zconnect-catalogo-premium",
  "private": true,
  "version": "12.5.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "postbuild": "node scripts/sync-catalog-analytics.mjs",
    "test": "node --test tests/*.test.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "generate-search-index": "node scripts/generate-search-index.mjs",
    "generate-catalog": "node scripts/generate-catalog.mjs",
    "sync-analytics": "node scripts/sync-catalog-analytics.mjs",
    "update-catalog": "npm run generate-catalog && npm run generate-search-index",
    "update-fast": "npm run update-catalog",
    "update-daily": "npm run update-catalog",
    "scrape": "npm run update-catalog",
    "estoque": "npm run update-catalog"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vite": "^5.4.21"
  },
  "type": "module"
}
